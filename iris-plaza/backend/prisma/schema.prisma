generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(uuid())
  email                String?               @unique
  phone                String                @unique
  password             String?
  role                 UserRole              @default(TENANT)
  firstName            String
  lastName             String
  isActive             Boolean               @default(true)
  isApproved           Boolean               @default(false)
  accountStatus        AccountStatus         @default(PENDING)
  isEmailVerified      Boolean               @default(false)
  isPhoneVerified      Boolean               @default(false)
  emailVerifyToken     String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  dob                  DateTime?
  auditLogs            AuditLog[]
  bookings             Booking[]
  cancellationRequests CancellationRequest[]
  documents            Document[]
  extensionRequests    ExtensionRequest[]
  tickets              MaintenanceTicket[]
  notifications        Notification[]
  otps                 Otp[]
  payments             Payment[]
  refreshTokens        RefreshToken[]
  rentCycles           RentCycle[]
  tenantProfile        TenantProfile?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Otp {
  id            String   @id @default(uuid())
  phone         String   @unique
  hashedOtp     String
  expiresAt     DateTime
  attemptsCount Int      @default(0)
  isVerified    Boolean  @default(false)
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

model TenantProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  dateOfBirth       DateTime?
  gender            String?
  occupation        String?
  companyName       String?
  monthlyIncome     Decimal?  @db.Decimal(10, 2)
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  kycStatus         String    @default("NOT_STARTED")
  kycVerifiedAt     DateTime?
  moveInDate        DateTime?
  moveOutDate       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tenant_profiles")
}

model Room {
  id            String        @id @default(uuid())
  name          String
  type          RoomType
  description   String?
  floor         Int
  area          Int
  rent          Decimal       @db.Decimal(10, 2)
  deposit       Decimal       @db.Decimal(10, 2)
  status        RoomStatus    @default(AVAILABLE)
  isAvailable   Boolean       @default(true)
  occupiedFrom  DateTime?
  occupiedUntil DateTime?
  availableAt   DateTime?
  videoUrl      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  
  // Management-specific fields (used by Admin Room Management & Tenant)
  // These are separate from the listing fields below
  managementRent      Decimal?  @db.Decimal(10, 2)
  managementStatus    RoomStatus? @default(AVAILABLE)
  managementIsAvailable Boolean? @default(true)
  managementOccupiedUntil DateTime?
  
  // Relations
  bookings      Booking[]
  amenities     RoomAmenity[]
  images        RoomImage[]
  media         RoomMedia[]

  @@map("rooms")
}

model RoomMedia {
  id        String   @id @default(uuid())
  roomId    String
  type      String
  url       String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_media")
}

model RoomImage {
  id        String   @id @default(uuid())
  roomId    String
  url       String
  caption   String?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_images")
}

model Amenity {
  id          String        @id @default(uuid())
  name        String        @unique
  icon        String?
  description String?
  createdAt   DateTime      @default(now())
  rooms       RoomAmenity[]

  @@map("amenities")
}

model RoomAmenity {
  id        String  @id @default(uuid())
  roomId    String
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  room      Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, amenityId])
  @@map("room_amenities")
}

model Booking {
  id                  String                 @id @default(uuid())
  userId              String
  roomId              String
  status              BookingStatus          @default(PENDING)
  startDate           DateTime
  endDate             DateTime?
  moveInDate          DateTime?
  moveOutDate         DateTime?
  checkoutDate        DateTime?
  bookingFee          Decimal?               @db.Decimal(10, 2)
  bookingFeePaid      Boolean                @default(false)
  expiresAt           DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deletedAt           DateTime?
  bookingSource       BookingSource          @default(WALK_IN)
  brokerName          String?
  tenantType          TenantType             @default(ACTIVE)
  expectedMoveIn      DateTime?
  bookingDate         DateTime?
  // Tenant-specific rent - overrides room.rent for this booking
  rentAmount          Decimal?               @db.Decimal(10, 2)
  agreement           Agreement?
  statusHistory       BookingStatusHistory[]
  room                Room                   @relation(fields: [roomId], references: [id])
  user                User                   @relation(fields: [userId], references: [id])
  cancellationRequest CancellationRequest?
  documents           Document[]
  extensionRequests   ExtensionRequest[]
  maintenanceTickets  MaintenanceTicket[]
  payments            Payment[]
  rentCycles          RentCycle[]

  @@map("bookings")
}

model BookingStatusHistory {
  id        String        @id @default(uuid())
  bookingId String
  status    BookingStatus
  comment   String?
  changedBy String?
  createdAt DateTime      @default(now())
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_status_history")
}

model Document {
  id           String         @id @default(uuid())
  userId       String
  bookingId    String?
  name         String
  type         DocumentType
  fileUrl      String
  fileName     String?
  fileSize     Int?
  mimeType     String?
  status       DocumentStatus @default(PENDING)
  rejectReason String?
  verifiedBy   String?
  verifiedAt   DateTime?
  uploadedAt   DateTime       @default(now())
  reviewedAt   DateTime?
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  booking      Booking?       @relation(fields: [bookingId], references: [id])
  user         User           @relation(fields: [userId], references: [id])

  @@map("documents")
}

model Agreement {
  id              String          @id @default(uuid())
  bookingId       String          @unique
  agreementUrl    String?
  status          AgreementStatus @default(DRAFT)
  tenantSigned    Boolean         @default(false)
  tenantSignedAt  DateTime?
  adminSigned     Boolean         @default(false)
  adminSignedAt   DateTime?
  startDate       DateTime
  endDate         DateTime
  monthlyRent     Decimal         @db.Decimal(10, 2)
  securityDeposit Decimal         @db.Decimal(10, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("agreements")
}

model Payment {
  id               String          @id @default(uuid())
  userId           String
  tenantId         String?
  roomId           String?
  bookingId        String?
  rentCycleId      String?
  invoiceId        String?
  amount           Decimal         @db.Decimal(10, 2)
  rentAmount       Decimal?        @db.Decimal(10, 2)
  paidAmount       Decimal?        @db.Decimal(10, 2)
  pendingAmount    Decimal?        @db.Decimal(10, 2)
  amountPaid       Decimal?        @db.Decimal(10, 2)
  borrowedAmount   Decimal?        @db.Decimal(10, 2)
  remainingAmount  Decimal?        @db.Decimal(10, 2)
  month            String
  type             PaymentType
  status           PaymentStatus   @default(PENDING)
  paymentMethod    PaymentMethod?  @default(ONLINE)
  screenshotUrl    String?
  transactionId    String?
  transactionDate  DateTime?
  paymentDate      DateTime?
  gateway          PaymentGateway?
  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewaySignature String?
  description      String?
  invoiceUrl       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  booking          Booking?        @relation(fields: [bookingId], references: [id])
  rentCycle        RentCycle?      @relation(fields: [rentCycleId], references: [id])
  user             User            @relation(fields: [userId], references: [id])

  @@map("payments")
}

model RentCycle {
  id             String          @id @default(uuid())
  userId         String
  bookingId      String
  month          Int
  year           Int
  amount         Decimal         @db.Decimal(10, 2)
  dueDate        DateTime
  paidDate       DateTime?
  status         RentCycleStatus @default(PENDING)
  lateFee        Decimal?        @db.Decimal(10, 2)
  lateFeeApplied Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  payments       Payment[]
  booking        Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id])

  @@unique([bookingId, year, month])
  @@map("rent_cycles")
}

model MaintenanceTicket {
  id              String         @id @default(uuid())
  tenantId        String
  bookingId       String?
  title           String
  description     String
  category        String
  requestedAmount Decimal?       @db.Decimal(10, 2)
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus   @default(OPEN)
  resolvedAt      DateTime?
  resolution      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  booking         Booking?       @relation(fields: [bookingId], references: [id])
  tenant          User           @relation(fields: [tenantId], references: [id])

  @@map("maintenance_tickets")
}

model ExtensionRequest {
  id                    String                 @id @default(uuid())
  bookingId             String
  tenantId              String
  currentCheckoutDate   DateTime
  requestedCheckoutDate DateTime
  reason                String?
  status                ExtensionRequestStatus @default(PENDING)
  approvedAt            DateTime?
  approvedBy            String?
  rejectionReason       String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  booking               Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tenant                User                   @relation(fields: [tenantId], references: [id])

  @@map("extension_requests")
}

model CancellationRequest {
  id              String                    @id @default(uuid())
  bookingId       String                    @unique
  tenantId        String
  reason          String?
  status          CancellationRequestStatus @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  releaseTime     DateTime?
  requestedAt     DateTime                  @default(now())
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  booking         Booking                   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tenant          User                      @relation(fields: [tenantId], references: [id])

  @@map("cancellation_requests")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model SystemSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  isPublic    Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model room_rules {
  id      BigInt @id @default(autoincrement())
  room_id String
  rule    String

  @@index([room_id], map: "idx_room_rules_room_id")
}

model room_transfers {
  id                    BigInt    @id @default(autoincrement())
  booking_id            String
  user_id               String
  from_room_id          String
  to_room_id            String
  effective_date        DateTime  @db.Timestamptz(6)
  desired_move_out_date DateTime? @db.Timestamptz(6)
  status                String    @default("PENDING")
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime  @default(now()) @db.Timestamptz(6)

  @@index([effective_date, status], map: "idx_room_transfers_effective_status")
  @@index([to_room_id, status], map: "idx_room_transfers_to_room_pending")
}

enum UserRole {
  ADMIN
  TENANT
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum RoomType {
  ONE_BHK
  TWO_BHK
  PENT_HOUSE
  SINGLE
  DOUBLE
  STUDIO
  SUITE
  THREE_BHK
  PENTHOUSE
}

enum RoomStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  MAINTENANCE
}

enum BookingSource {
  WALK_IN
  BROKER
}

enum BookingStatus {
  PENDING
  PENDING_APPROVAL
  RESERVED
  VERIFICATION_PENDING
  APPROVED_PENDING_PAYMENT
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum TenantType {
  ACTIVE
  FUTURE
}

enum DocumentStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum DocumentType {
  AADHAAR
  COLLEGE_ID
  TENANT_PHOTO
  ID_CARD
  PROOF_OF_INCOME
  ADDRESS_PROOF
  PHOTO
  AGREEMENT
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIAL
  NEEDS_REVIEW
  PENDING_VERIFICATION
}

enum PaymentType {
  BOOKING_FEE
  RENT
  DEPOSIT
  LATE_FEE
  OTHER
}

enum PaymentMethod {
  ONLINE
  CASH
  UPI
  BANK_TRANSFER
}

enum PaymentGateway {
  RAZORPAY
  CASHFREE
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  PENDING_SIGNATURE
  SIGNED
  EXPIRED
}

enum RentCycleStatus {
  PENDING
  PAID
  OVERDUE
  PARTIALLY_PAID
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  SMS
  EMAIL
  PUSH
  RENT_REMINDER
  RENT_OVERDUE
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  MAINTENANCE_UPDATE
  ANNOUNCEMENT
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
  UNREAD
}

enum ExtensionRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum CancellationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}
